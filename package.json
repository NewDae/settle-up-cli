{
  "name": "settle-up-cli",
  "private": true,
  "type": "module",
  "bin": {
    "settleup": "./bin/settleup.mjs"
  },
  "scripts": {
    "test": "node --test test/cli-*.test.mjs test/negative-inputs.test.mjs test/spec-contracts.test.mjs",
    "test:live": "SETTLEUP_RUN_LIVE=1 node --test test/sandbox-live.test.mjs",
    "test:all": "node --test test/*.test.mjs",
    "integration:e2e": "node scripts/run-cli-integration.mjs",
    "integration:e2e:staging": "SETTLEUP_ENV_FILE=.env.staging node scripts/run-cli-integration.mjs",
    "integration:e2e:prod": "SETTLEUP_ENV_FILE=.env.production node scripts/run-cli-integration.mjs"
  }
}
